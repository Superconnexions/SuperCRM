                    function CustomizeData(data) {
                        var temOdrs = [];
                        temOdrs = data;
                        for (var i = 0; temOdrs.length > i; i++) {
                            if (temOdrs[i].ServiceName != "") {
                                temOdrs[i].ServiceName = temOdrs[i].ServiceName;
                            }
                            if (temOdrs[i].AssignedTo == "" || temOdrs[i].AssignedTo == null) {
                                temOdrs[i].AssignedTo = "Not assigned";
                            }
                            if (temOdrs[i].StatusId == 'Received' || temOdrs[i].StatusId == 'Confirmed') {
                                temOdrs[i].StatusId = true;
                            } else {
                                temOdrs[i].StatusId = false;
                            }

                            var imgnam = GetImageName(temOdrs[i].ServiceId, temOdrs[i].ServiceCategoryId);
                            temOdrs[i].ImageName = imgnam;
                        }
                        return temOdrs;
                    };

                    var GetCurrentDateTime = function () {

                        function formatDate(date) {
                            var hours = date.getHours();
                            var minutes = date.getMinutes();
                            var ampm = hours >= 12 ? 'pm' : 'am';
                            hours = hours % 12;
                            hours = hours ? hours : 12; // the hour '0' should be '12'
                            minutes = minutes < 10 ? '0' + minutes : minutes;
                            var strTime = hours + ':' + minutes + ' ' + ampm;
                            return date.getMonth() + 1 + "/" + date.getDate() + "/" + date.getFullYear() + "  " + strTime;
                        }

                        var d = new Date();
                        var e = formatDate(d);

                        return e;
                    };



