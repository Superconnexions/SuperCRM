@model SuperCRM.Web.ViewModels.Agents.AgentDashboardViewModel

@{
    ViewData["Title"] = "Agent Dashboard";
}
@section Style{
    <style type="text/css">
        #mySelect {
            font-size: x-large !important;
            color:blue;
        }
        .selectTypeFontS {
            font-size: x-large !important;
        }
        .fontweightB {
            font-weight:bold;
        }
        .floatN {
         float:none !important;
        }
        .table > :not(caption) > * > * {
            color: white;
            background-color: #242526;
        }
        .table-borderless span {
            color: lightslategray;
            font-weight: bold;
            text-transform: uppercase;
        }

        .document-upload-box .upload-box-info h3 {
            top: -20px;
        }
        .instant-block:after {
            border-bottom-color: #242526;
        }
        .rps {
            color: gray;
            font-weight: normal;
            font-size: smaller;
        }
        .rpintg {
            max-height:35px !important;
        }
        .reduce-box input::placeholder {
            color: #b1b3b8;
        }
        .businessType {
            width: fit-content;
            text-align: left;
           /* margin-left: 15%;*/
        }

        .marginLeft15p {
            margin-left: 15%;
        }
        .marginLeft23p {
          margin-left:23%;
        }

        .ProductDiv {
         margin-top:-5%;
        }

        .instant-block {
            padding: 5px;
            border: 2px groove #0d6efd;
        }
            .instant-block:before {
                border-bottom-color: #0d6efd;
            }
        .customerInfoDiv {
             margin-bottom: 5%;
        }
        .dPdcInfTbl thead {
            border-bottom-width: thin;
        }
            .dPdcInfTbl tr {
            border-bottom-width: thin;
            border-bottom-style: dashed;
        }

        .CustomerTypeHead .document-upload-box {
            border: 2px groove #6b4fc6;
            padding: 20px;
            margin: initial;
        }

        .CustomerTypeHead .cmr-vid-list-blk {
            margin-bottom: auto;
        }

        .CustomerTypeHead .document-upload-box:hover {
            cursor: pointer;
        }

        .CustomerTypeHead .cmr-vid-list-info a {
            text-decoration: none;
        }

        .TwoType {
            max-width: none !important;
            top: -15px !important;
            color: blue !important;
        }
            .TwoType .tleft {
                font-weight: bold;
                color: blue;
                text-transform: uppercase;
                font-size: large;
            }

        .CTHeader {
            font-size: x-large !important;
            margin-top: 2% !important;
            color: cornflowerblue !important;
            text-align: center !important;
        }

        .is-same-bankinfo-checkDiv .form-check {
         margin-top:4%!important;
        }

         .B_TypeSL .cmr-vid-list-img {
          width:20% !important;
        }
       .B_TypeSL .cmr-vid-list-info {
            margin-top: 6% !important;
           
        }
        .B_TypeSL .cmr-vid-list-blk {
            height: 40% !important;
        }
    </style>
}
       
  
