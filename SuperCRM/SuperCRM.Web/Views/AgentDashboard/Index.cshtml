                    function isValidePhoneNo(phoneNo) {
                        var rValue = false;
                        var len = 11;
                        var cellPhonePattrent = true;
                        if (phoneNo == '' || phoneNo == "" || phoneNo == null || phoneNo == undefined) {
                            alert("Phone number is required.");
                            rValue = false;
                        } else {
                            if (phoneNo.charAt(0) == "+") {
                                len = 14;
                            } else if (phoneNo.charAt(0) == "8" && phoneNo.charAt(1) == "8" && phoneNo.charAt(2) == "0" && phoneNo.charAt(3) == "1") {
                                len = 13;
                            } else if (phoneNo.charAt(0) == "0" && phoneNo.charAt(1) == "1") {
                                len = 11;
                            } else {
                                cellPhonePattrent = false;
                            };

                            if (cellPhonePattrent) {
                                if (phoneNo.length < len || phoneNo.length > len) {
                                    alert("Phone number Length not match.");
                                    rValue = false;
                                } else {
                                    rValue = true;
                                };
                            } else {
                                alert("Phone number code not match.");
                                rValue = false;
                            };
                        };

                        return rValue;
                    };
