@model SuperCRM.Web.ViewModels.ProductCategories.ProductCategoryCreateEditViewModel

<div asp-validation-summary="All" class="text-danger"></div>

<div class="mb-3">
    <label asp-for="CategoryCode" class="form-label"></label>
    <input asp-for="CategoryCode" class="form-control" />
    <span asp-validation-for="CategoryCode" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CategoryName" class="form-label"></label>
    <input asp-for="CategoryName" class="form-control" />
    <span asp-validation-for="CategoryName" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CategoryImageUrl" class="form-label"></label>
    <input asp-for="CategoryImageUrl" class="form-control" readonly />
    <span asp-validation-for="CategoryImageUrl" class="text-danger"></span>

    @if ( !string.IsNullOrEmpty(Model.CategoryImageUrl) )
    
    {
        
    <div style="margin-top:10px">
        <img src="@Model.CategoryImageUrl" alt="Category Image" style="max-width:150px; max-height:100px;margin-top:10px" />
    </div>    }
    

</div>

<div class="mb-3">
    <label asp-for="DisplayNotes" class="form-label"></label>
    <textarea asp-for="DisplayNotes" class="form-control" rows="3"></textarea>
    <span asp-validation-for="DisplayNotes" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="DisplayOrder" class="form-label"></label>
    <input asp-for="DisplayOrder" class="form-control" />
    <span asp-validation-for="DisplayOrder" class="text-danger"></span>
</div>

<div class="form-check mb-3">
    <input asp-for="IsActive" class="form-check-input" />
    <label asp-for="IsActive" class="form-check-label"></label>
</div>
<span asp-validation-for="IsActive" class="text-danger"></span>
