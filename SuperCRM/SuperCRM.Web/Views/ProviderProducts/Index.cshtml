@model SuperCRM.Web.ViewModels.ProviderProducts.ProviderProductIndexViewModel

@{
    ViewData["Title"] = "Provider Products";
}

<h2>Provider Products</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form method="get" asp-action="Index" class="row g-3 mb-3">
    <div class="col-md-4">
        <label class="form-label">Provider</label>
        <input asp-for="SearchProviderName" name="searchProviderName" class="form-control" placeholder="Search by provider" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Product</label>
        <input asp-for="SearchProductName" name="searchProductName" class="form-control" placeholder="Search by product or product code" />
    </div>
    <div class="col-md-4 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
        <a asp-action="Create" class="btn btn-success">Add Provider Product</a>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Provider</th>
            <th>Product Code</th>
            <th>Product Name</th>
            <th style="width:180px;">Action</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Items.Any())
    {
        foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProviderName</td>
                <td>@item.ProductCode</td>
                <td>@item.ProductName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ProviderProductId" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@item.ProviderProductId" method="post" class="d-inline"
                          onsubmit="return confirm('Are you sure you want to delete this Provider Product?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="4" class="text-center">No records found.</td>
        </tr>
    }
    </tbody>
</table>
