@model SuperCRM.Web.ViewModels.ProductVariants.ProductVariantCreateEditViewModel

@{
    ViewData["Title"] = "Edit Product Variant";
}

<h2>Edit Product Variant</h2>

<form asp-action="Edit" method="post">
    <input asp-for="ProductVariantId" type="hidden" />
    <partial name="_Form" model="Model" />

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
