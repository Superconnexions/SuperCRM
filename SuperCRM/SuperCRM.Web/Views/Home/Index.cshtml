@model SuperCRM.Web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_SecondLayout";
}
@section Style{
      
       <style>
          
       </style>
}


   <div class="loginMain" >
       
            <div class="container-fluid">
       
                    <div class="row" style="justify-content: center;">
                        <div class="col-md-12 col-lg-4">
                            <div class="cmr-vid-dash">
                                <div class="row">
                                    <div class="col-lg-12">
                                        <div class="cmr-vid-wrap">
                                            <h2 style="text-align: center;">Welcome to SuperCMR HOME</h2>
                                            <div class="cmr-vid-img" style="display:none">
                                                <!-- <img src="images/SignupImg.jpg" alt="img"> -->
                                                <img src="images/signupimg1.jpg" alt="img">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-12">
                                        <div class="cmr-quick-blk">
                                            <div class="space-30"></div>
                                           @* <p>SuperCMR Home is designed to put you in control of your time and income, so you can live the lifestyle you’ve always wanted! It has already created easy Income Earners and you could be next.</p>

                                            <h2 class="text-center"> Are you ready to use?</h2> *@
                                            <h6 class="text-center" style="color: #00b4ff;">Please Log In to Your Account</h6>

                                            <div class="cmr-cleint">
                                                <div class="row">

                                                   <form asp-action="Login" method="post">
                                                      <div asp-validation-summary="All" class="text-danger"></div>
                                                      <div class="col-md-12">
                                                        <h4>Email</h4>
                                                        <div class="form-group">
                                                            <!-- <label>New Email</label> -->
                                                            <input asp-for="UserName" type="text" class="form-control" placeholder="Enter your email" style="">
                                                            <span asp-validation-for="UserName" class="text-danger"></span>
                                                        </div>
                                                    </div>
                                                      <div class="col-md-12">
                                                        <h4>Password</h4>
                                                        <div class="form-group">
                                                            <!-- <label>New Email</label> -->
                                                            <input asp-for="Password" type="text" class="form-control" placeholder="Enter your password">
                                                            <span asp-validation-for="Password" class="text-danger"></span>
                                                        </div>
                                                    </div>
                                                      <div class="col-md-12">
                                                        <div class="form__col form__col--12 form__col--flex">
                                                            <label class="form__field form__field--checkbox">
                                                                <span class="checkbox">
                                                                    <span class="checkbox__wrap">
                                                                        <input asp-for="RememberMe" class="checkbox__default" type="checkbox" id="RememberMe" name="RememberMe" data-val="true" value="true"><span class="checkbox__custom"></span>
                                                                    </span>
                                                                </span><span class="form__field-name" style="color:#a1a1a1; padding-right: 10px;">Keep me logged in</span>
                                                                </label><a class="form__primary-btn" asp-controller="Home" asp-action="ForgotPassword">Forgot Password?</a>
                                                        </div>
                                                    </div>
                                                      <div class="col-md-12">
                                                        <div class="form__col form__col--12">
                                                            <button class="signin-btn form__submit" type="submit" id="SigninBtn" ><span class="value">Sign in</span></button>
                                                            <!--<a class="signin-btn form__submit" href="#">Sign in</a>-->
                                                        </div>
                                                    </div>
                                                   </form>
                                                    
                                                    <div class="col-md-12">
                                                        <div class="scs form__col form__col--12">
                                                            <div class="form__question">
                                                    <p>Don’t have an account?</p><a class="form__primary-btn no-border-link" href="/AgentRegistration/Register">Please Sign up or Contact our support team.</a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <div class="login-footer">
                                                            <p>©2025-2026 Supper CMR. All rights reserved.</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

            </div>
    
    </div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
                   
    </script>
}