@model SuperCRM.Web.ViewModels.AgentManagement.AgentListViewModel

@{
    ViewData["Title"] = "Agent Management";
}

<h1>Agent Management</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<form asp-action="Index" method="get" class="row g-3 mb-3">
    <div class="col-md-4">
        <label asp-for="SearchText" class="form-label"></label>
        <input asp-for="SearchText" class="form-control" placeholder="Agent Code, Email, First Name, Last Name, Phone No, Mobile No" />
    </div>

    <div class="col-md-3">
        <label asp-for="IsApproved" class="form-label"></label>
        <select asp-for="IsApproved" asp-items="Model.IsApprovedOptions" class="form-select"></select>
    </div>

    <div class="col-md-3">
        <label asp-for="RegistrationStatus" class="form-label"></label>
        <select asp-for="RegistrationStatus" asp-items="Model.RegistrationStatusOptions" class="form-select"></select>
    </div>

    <div class="col-md-2 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Agent Code</th>
            <th>Email</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Phone No</th>
            <th>Mobile No</th>
            <th>Is Approved</th>
            <th>Registration Status</th>
            <th style="width:100px;">Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.AgentCode</td>
                    <td>@item.Email</td>
                    <td>@item.FirstName</td>
                    <td>@item.LastName</td>
                    <td>@item.PhoneNo</td>
                    <td>@item.MobileNo</td>
                    <td>@item.IsApprovedText</td>
                    <td>@item.RegistrationStatusName</td>
                    <td>
                        <a asp-action="ViewRegistration" asp-route-id="@item.AgentId" class="btn btn-sm btn-info">View</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center">No agents found.</td>
            </tr>
        }
    </tbody>
</table>
