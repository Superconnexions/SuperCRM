@model IEnumerable<SuperCRM.Web.ViewModels.ProductVariantTypes.ProductVariantTypeListItemViewModel>

@{
    ViewData["Title"] = "Product Variant Types";
}

<h2>Product Variant Types</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Add Product Variant Type</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Type Code</th>
            <th>Type Value</th>
            <th>Display Order</th>
            <th>Active</th>
            <th style="width:120px;">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TypeCode</td>
                <td>@item.TypeValue</td>
                <td>@item.DisplayOrder</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.TypeCode" class="btn btn-sm btn-warning">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>